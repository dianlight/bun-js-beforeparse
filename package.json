{
  "name": "bun-js-beforeparse",
  "version": "0.2.0"
  "description": "Use any JavaScript/TypeScript function as a Bun bundler onBeforeParse plugin",
  "main": "js/index.js",
  "types": "js/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dianlight/bun-js-beforeparse.git"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": ["bun", "bundler", "plugin", "napi", "transform", "onBeforeParse"],
  "napi": {
    "binaryName": "bun-js-beforeparse",
    "packageName": "bun-js-beforeparse",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "bun test __test__/basic.test.ts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  },
  "files": [
    "js/",
    "*.node"
  ]
}
