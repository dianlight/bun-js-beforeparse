{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "js",
    "outDir": "js"
  },
  "include": ["js/**/*.ts"],
  "exclude": ["node_modules", "target", "__test__"]
}
